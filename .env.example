# Config de la app (Vite). Copiá lo que necesites a `.env.production` (para el sitio
# publicado) o `.env.local` (para tu máquina). Los valores VITE_* se inyectan en el
# build y quedan visibles en el navegador → NO poner acá nada secreto.
#
# El website-id de Umami y la URL de Tally NO son secretos (se ven en la página), así
# que van tranquilos en `.env.production` commiteado, para que el deploy los tome.

# ─── Analytics ───────────────────────────────────────────────
# Proveedor: 'umami' | 'plausible' | vacío (sin analytics).
VITE_ANALYTICS_PROVIDER=umami

# Umami (https://umami.is). Sacá estos dos valores del panel de Umami, en el
# "tracking code" de tu sitio (Settings → Websites → tu sitio).
VITE_UMAMI_SRC=https://cloud.umami.is/script.js
VITE_UMAMI_WEBSITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Plausible (alternativa a Umami — dejar vacío si usás Umami).
# VITE_PLAUSIBLE_SRC=https://plausible.io/js/script.js
# VITE_PLAUSIBLE_DOMAIN=cuantomefalta.app

# ─── Feedback ────────────────────────────────────────────────
# URL del formulario de Tally (https://tally.so). Vacío = no aparece el botón.
VITE_FEEDBACK_URL=https://tally.so/r/xxxxxx

# ─── Backend: auth + sync (Supabase) ─────────────────────────
# Vacío = la app corre 100% local, sin login (como el modo original).
# La ANON_KEY es la clave *publishable* (pública por diseño; la protege el RLS).
# La clave *secret*/service_role NUNCA va acá ni en el repo.
# En dev estas van en `.env.local` (gitignoreado); en producción se commitean a
# `.env.production` recién cuando el sync esté terminado.
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx
